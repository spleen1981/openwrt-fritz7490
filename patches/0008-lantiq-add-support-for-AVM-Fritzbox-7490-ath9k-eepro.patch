From 4b743650c8784c67fd0fbfc8d8daaa442b6d992d Mon Sep 17 00:00:00 2001
From: Zappception <79199928+Zappception@users.noreply.github.com>
Date: Thu, 6 Feb 2025 17:33:04 +0100
Subject: [PATCH 08/14] lantiq: add support for AVM Fritzbox 7490 ath9k eeprom
 and ath10k caldata

---
 .../etc/hotplug.d/firmware/11-ath10k-caldata  | 27 +++++++++++++++++++
 .../etc/hotplug.d/firmware/12-ath9k-eeprom    |  5 +++-
 2 files changed, 31 insertions(+), 1 deletion(-)
 create mode 100644 target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/11-ath10k-caldata

diff --git a/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/11-ath10k-caldata b/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/11-ath10k-caldata
new file mode 100644
index 0000000000..8debd98308
--- /dev/null
+++ b/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/11-ath10k-caldata
@@ -0,0 +1,27 @@
+#!/bin/sh
+
+[ -e /lib/firmware/$FIRMWARE ] && exit 0
+
+. /lib/functions/caldata.sh
+
+case "$FIRMWARE" in
+"ath10k/cal-pci-0000:00:00.0.bin"|\
+"ath10k/cal-pci-0000:02:00.0.bin")
+	board=$(board_name)
+	case $board in
+		avm,fritz7490|avm,fritz7490-micron)
+			[ ! -d /lib/firmware/ath10k ] && mkdir /lib/firmware/ath10k
+			offset=$(hexdump -v -e '1/1 "%02x"' $(find_mtd_chardev "urlader") | awk '{print index($0, "4408")}')
+			let "offset = ($offset - 1) / 2"
+			caldata_extract "urlader" $offset 0x844
+			;;
+		bt,homehub-v5a)
+			caldata_extract_ubi "caldata" 0x5000 0x844
+			ath10k_patch_mac $(macaddr_add $(mtd_get_mac_binary_ubi caldata 0x110c) 3)
+			;;
+		*)
+			caldata_die "board $board is not supported yet"
+			;;
+	esac
+	;;
+esac
diff --git a/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/12-ath9k-eeprom b/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/12-ath9k-eeprom
index a3968b2303..319aacb67e 100644
--- a/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/12-ath9k-eeprom
+++ b/target/linux/lantiq/xrx200/base-files/etc/hotplug.d/firmware/12-ath9k-eeprom
@@ -5,6 +5,7 @@
 . /lib/functions/caldata.sh
 
 case "$FIRMWARE" in
+	"ath9k-eeprom-ahb-18100000.wmac.bin" | \
 	"ath9k-eeprom-pci-0000:00:0e.0.bin" | \
 	"ath9k-eeprom-pci-0000:01:00.0.bin" | \
 	"ath9k-eeprom-pci-0000:02:00.0.bin")
@@ -13,7 +14,9 @@ case "$FIRMWARE" in
 		case "$board" in
 			avm,fritz3370-rev2-hynix|\
 			avm,fritz3370-rev2-micron|\
-			avm,fritz7362sl)
+			avm,fritz7362sl|\
+			avm,fritz7490|\
+			avm,fritz7490-micron)
 				caldata_extract_reverse "urlader" 0x1541 0x440
 				;;
 			avm,fritz3390)
-- 
2.43.0

